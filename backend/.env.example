# ==================================
# CodeJudge Backend — Environment Variables
# ==================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/codejudge?retryWrites=true&w=majority

# Judge0 API (RapidAPI)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com

# Server port
PORT=5000
